OPENAI_API_KEY="your_openai_api_key_here"

# For Google Imagen, you need a Service Account key file and your Project ID.
# 1. Create a service account in the Google Cloud Console with "Vertex AI User" role.
# 2. Download the JSON key file and place it in the `functions` directory as `google.json`.
# 3. Add your Google Cloud Project ID below.
GOOGLE_PROJECT_ID="your-google-cloud-project-id"
